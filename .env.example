# ==========================================================
# TEMPLATE -- copy ke .env.development / .env.staging / .env.production
# ==========================================================

# ====== APP ======
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ====== LOGGING ======
LOG_LEVEL=info

# ====== DATABSE - aktifkan sesuai kebutuhan ======
DB_MYSQL=false
DB_POSTGRES=true
DB_MONGO=false

# ====== MySQL ======
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=app_db
# Alias untuk Docker image MySQL (harus sama dengan MYSQL_PASSWORD)
MYSQL_ROOT_PASSWORD=

# ====== PostgreSQL ======
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=app_db

# ====== MongoDB ======
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_DATABASE=app_db
# Alias untuk Docker image MongoDB
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
MONGO_INITDB_DATABASE=app_db

# ====== ENCRYPTION ======
DB_ENCRYPTION_KEY=
DB_HMAC_KEY=
RSA_PRIVATE_KEY=
RSA_PUBLIC_KEY=