# ==========================================================
# DEVELOPMENT
# Database connect ke Docker container di localhost
# ==========================================================

# ====== APP ======
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ====== LOGGING ======
LOG_LEVEL=info

# ====== DATABSE - aktifkan sesuai kebutuhan ======
DB_MYSQL=false
DB_POSTGRES=true
DB_MONGO=false

# ====== MySQL ======
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=K!c4UMaN1A
MYSQL_DATABASE=app_db
# Alias untuk Docker image MySQL (harus sama dengan MYSQL_DATABASE)
MYSQL_ROOT_PASSWORD=K!c4UMaN1A

# ====== PostgreSQL ======
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=K!c4UMaN1A
POSTGRES_DB=app_db

# ====== MongoDB ======
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=root
MONGO_PASSWORD=K!c4UMaN1A
MONGO_DATABASE=app_db
# Alias untuk Docker image MongoDB
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=K!c4UMaN1A
MONGO_INITDB_DATABASE=app_db

